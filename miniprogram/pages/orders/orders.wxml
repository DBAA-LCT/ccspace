<view class="page">
  <form class="search-bar panel" bindsubmit="searchOrders">
    <t-input name="phone" value="{{phone}}" placeholder="输入下单人或老人手机号" type="number" />
    <t-button theme="primary" form-type="submit" shape="round">查询</t-button>
  </form>

  <view wx:if="{{loading}}" class="loading panel">
    <text>正在加载订单...</text>
  </view>

  <view wx:elif="{{orders.length === 0}}" class="empty panel">
    <t-empty description="暂无订单" />
  </view>

  <view wx:else class="order-list">
    <view wx:for="{{orders}}" wx:key="id" class="order-card panel">
      <view class="order-head">
        <view>
          <text class="order-no">{{item.orderNo}}</text>
          <text class="muted">{{item.createdText}}</text>
        </view>
        <view class="status {{item.statusClass}}">{{item.statusText}}</view>
      </view>
      <view class="receiver">
        <text class="receiver-name">{{item.receiverName}} {{item.receiverPhone}}</text>
        <text class="muted">{{item.address}}</text>
      </view>
      <view class="items">
        <text wx:for="{{item.items}}" wx:key="productId" class="item-line">{{item.name}} x {{item.quantity}}</text>
      </view>
      <view class="order-foot">
        <text class="muted">{{item.note}}</text>
        <text class="price">￥{{item.totalYuan}}</text>
      </view>
    </view>
  </view>
</view>
