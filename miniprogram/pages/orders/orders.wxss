.search-bar {
  display: grid;
  grid-template-columns: 1fr 148rpx;
  gap: 14rpx;
  margin-bottom: 24rpx;
  padding: 18rpx;
}

.order-list {
  display: grid;
  gap: 18rpx;
}

.order-card {
  padding: 24rpx;
}

.order-head,
.order-foot {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.order-no {
  display: block;
  margin-bottom: 6rpx;
  font-weight: 600;
  font-size: 26rpx;
  color: #171717;
}

.receiver,
.items {
  display: grid;
  gap: 8rpx;
  margin-top: 18rpx;
}

.receiver-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #171717;
}

.items {
  padding: 16rpx 0;
  border-top: 1rpx solid #ebebeb;
  border-bottom: 1rpx solid #ebebeb;
}

.item-line {
  font-size: 26rpx;
  color: #4d4d4d;
  line-height: 1.6;
}

.photo-section {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #ebebeb;
}

.photo-label {
  display: block;
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.delivery-photo {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
}

.order-foot {
  margin-top: 18rpx;
}

.foot-left {
  flex: 1;
  min-width: 0;
}

.order-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #ebebeb;
}
