.search {
  display: grid;
  grid-template-columns: 1fr 148rpx;
  gap: 14rpx;
  margin-bottom: 24rpx;
  padding: 18rpx;
}

.search input {
  min-height: 76rpx;
  border: 1rpx solid #ded8cb;
  border-radius: 10rpx;
  padding: 0 16rpx;
  background: #fff;
}

.loading,
.empty {
  padding: 48rpx 24rpx;
  color: #6d675d;
  text-align: center;
}

.order-list {
  display: grid;
  gap: 18rpx;
}

.order-card {
  padding: 22rpx;
}

.order-head,
.order-foot {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.order-no {
  display: block;
  margin-bottom: 6rpx;
  font-weight: 700;
}

.receiver,
.items {
  display: grid;
  gap: 8rpx;
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.45;
}

.order-foot {
  margin-top: 18rpx;
}

