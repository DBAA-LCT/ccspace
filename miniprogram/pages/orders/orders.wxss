.search-bar {
  display: grid;
  grid-template-columns: 1fr 148rpx;
  gap: 14rpx;
  margin-bottom: 24rpx;
  padding: 18rpx;
}

.order-list {
  display: grid;
  gap: 18rpx;
}

.order-card {
  padding: 24rpx;
}

.order-head,
.order-foot {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.order-no {
  display: block;
  margin-bottom: 6rpx;
  font-weight: 600;
  font-size: 26rpx;
  color: #171717;
}

.receiver,
.items {
  display: grid;
  gap: 8rpx;
  margin-top: 18rpx;
}

.receiver-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #171717;
}

.items {
  padding: 16rpx 0;
  border-top: 1rpx solid #ebebeb;
  border-bottom: 1rpx solid #ebebeb;
}

.item-line {
  font-size: 26rpx;
  color: #4d4d4d;
  line-height: 1.6;
}

.order-foot {
  margin-top: 18rpx;
}

.status {
  display: inline-flex;
  align-items: center;
  min-height: 40rpx;
  border-radius: 100rpx;
  padding: 0 16rpx;
  font-size: 24rpx;
  font-weight: 500;
  white-space: nowrap;
}

.status.status-success {
  color: #1a7f37;
  background: #dafbe1;
}

.status.status-warning {
  color: #ab570a;
  background: #ffefcf;
}

.status.status-error {
  color: #c50000;
  background: #f7d4d6;
}

.status.status-info {
  color: #0070f3;
  background: #d3e5ff;
}
