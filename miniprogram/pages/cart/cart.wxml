<view class="page">
  <view wx:if="{{cart.length === 0}}" class="empty panel">
    <t-empty description="购物车为空" />
    <t-button theme="primary" shape="round" block bindtap="goHome">去选商品</t-button>
  </view>

  <block wx:else>
    <view class="cart-list panel">
      <view wx:for="{{cart}}" wx:key="id" class="cart-item">
        <image class="cart-image" mode="aspectFill" src="{{item.imageUrl}}"></image>
        <view class="cart-info">
          <text class="cart-name">{{item.name}}</text>
          <text class="muted">￥{{item.priceYuan}} / {{item.unit}}</text>
          <view class="quantity">
            <t-stepper value="{{item.quantity}}" min="1" max="{{item.stock}}" data-id="{{item.id}}" bind:change="changeQuantity" />
            <t-button variant="text" size="small" data-id="{{item.id}}" bindtap="remove" class="remove-btn">
              移除
            </t-button>
          </view>
        </view>
      </view>
      <view class="total-row">
        <text class="total-label">合计</text>
        <text class="price total-value">￥{{totalYuan}}</text>
      </view>
    </view>

    <view class="panel order-form">
      <view class="form-section-title">送达时间</view>
      <scroll-view scroll-x class="date-scroll">
        <view wx:for="{{deliveryDates}}" wx:key="value" class="date-chip {{selectedDateIndex === index ? 'date-active' : ''}}" data-index="{{index}}" bindtap="onSelectDate">
          {{item.label}}
        </view>
      </scroll-view>

      <t-input name="customerName" label="下单人" value="{{formData.customerName}}" data-field="customerName" bind:change="onFieldChange" placeholder="你的姓名" />
      <t-input name="customerPhone" label="手机号" value="{{formData.customerPhone}}" data-field="customerPhone" bind:change="onFieldChange" placeholder="用于查询订单" type="number" />
      <t-input name="receiverName" label="收货人" value="{{formData.receiverName}}" data-field="receiverName" bind:change="onFieldChange" placeholder="收货人姓名" />
      <t-input name="receiverPhone" label="联系电话" value="{{formData.receiverPhone}}" data-field="receiverPhone" bind:change="onFieldChange" placeholder="收货人电话" type="number" />
      <t-textarea name="address" label="配送地址" value="{{formData.address}}" data-field="address" bind:change="onFieldChange" placeholder="村名、组名、门牌或明显地标" />

      <view class="form-section-title">备注</view>
      <view wx:if="{{noteTemplates.length > 0}}" class="note-templates">
        <text wx:for="{{noteTemplates}}" wx:key="*this" class="note-chip" data-text="{{item}}" bindtap="onNoteTemplate">{{item}}</text>
      </view>
      <t-textarea name="note" label="" value="{{formData.note}}" data-field="note" bind:change="onFieldChange" placeholder="例如：和快递一起送" />

      <t-button theme="primary" block shape="round" loading="{{submitting}}" bindtap="submitOrder">
        提交订单
      </t-button>
    </view>
  </block>
</view>
