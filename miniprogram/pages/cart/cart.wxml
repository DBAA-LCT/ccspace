<view class="page">
  <view wx:if="{{cart.length === 0}}" class="empty panel">
    <t-empty description="购物车为空" />
    <t-button theme="primary" shape="round" block bindtap="goHome">去选商品</t-button>
  </view>

  <block wx:else>
    <view class="cart-list panel">
      <view wx:for="{{cart}}" wx:key="id" class="cart-item">
        <image class="cart-image" mode="aspectFill" src="{{item.imageUrl}}"></image>
        <view class="cart-info">
          <text class="cart-name">{{item.name}}</text>
          <text class="muted">￥{{item.priceYuan}} / {{item.unit}}</text>
          <view class="quantity">
            <t-stepper value="{{item.quantity}}" min="1" max="{{item.stock}}" data-id="{{item.id}}" bind:change="changeQuantity" />
            <t-button variant="text" size="small" data-id="{{item.id}}" bindtap="remove" class="remove-btn">
              移除
            </t-button>
          </view>
        </view>
      </view>
      <view class="total-row">
        <text class="total-label">合计</text>
        <text class="price total-value">￥{{totalYuan}}</text>
      </view>
    </view>

    <view class="panel order-form">
      <t-input name="customerName" label="下单人" value="{{profile.customerName}}" data-field="customerName" bind:change="onFieldChange" placeholder="你的姓名" />
      <t-input name="customerPhone" label="手机号" value="{{profile.customerPhone}}" data-field="customerPhone" bind:change="onFieldChange" placeholder="用于查询订单" type="number" />
      <t-input name="receiverName" label="收货老人" value="{{profile.receiverName}}" data-field="receiverName" bind:change="onFieldChange" placeholder="老人姓名" />
      <t-input name="receiverPhone" label="老人电话" value="{{profile.receiverPhone}}" data-field="receiverPhone" bind:change="onFieldChange" placeholder="可填老人或邻居电话" type="number" />
      <t-textarea name="address" label="配送地址" value="{{profile.address}}" data-field="address" bind:change="onFieldChange" placeholder="村名、组名、门牌或明显地标" />
      <t-textarea name="note" label="备注" value="{{profile.note}}" data-field="note" bind:change="onFieldChange" placeholder="例如：和快递一起送、老人行动不便等" />
      <t-button theme="primary" block shape="round" loading="{{submitting}}" bindtap="submitOrder">
        提交订单
      </t-button>
    </view>
  </block>
</view>
