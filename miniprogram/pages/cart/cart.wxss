.empty {
  display: grid;
  gap: 24rpx;
  padding: 56rpx 28rpx;
  color: #888888;
  text-align: center;
}

.cart-list {
  overflow: hidden;
  margin-bottom: 24rpx;
}

.cart-item {
  display: grid;
  grid-template-columns: 128rpx 1fr;
  gap: 18rpx;
  padding: 20rpx;
  border-bottom: 1rpx solid #ebebeb;
}

.cart-item:last-child {
  border-bottom: none;
}

.cart-image {
  width: 128rpx;
  height: 128rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
}

.cart-info {
  display: grid;
  gap: 8rpx;
}

.cart-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #171717;
}

.quantity {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.remove-btn {
  color: #ee0000 !important;
}

.total-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-top: 1rpx solid #ebebeb;
}

.total-label {
  font-size: 28rpx;
  color: #4d4d4d;
}

.total-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #171717;
}

.order-form {
  padding: 24rpx;
}
