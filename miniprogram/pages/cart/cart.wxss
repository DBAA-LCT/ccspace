.empty {
  display: grid;
  gap: 24rpx;
  padding: 56rpx 28rpx;
  color: #666666;
  text-align: center;
}

.cart-list {
  overflow: hidden;
  margin-bottom: 24rpx;
}

.cart-item {
  display: grid;
  grid-template-columns: 128rpx 1fr;
  gap: 18rpx;
  padding: 20rpx;
  border-bottom: 1rpx solid #ebebeb;
}

.cart-item:last-child {
  border-bottom: none;
}

.cart-image {
  width: 128rpx;
  height: 128rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
}

.cart-info {
  display: grid;
  gap: 8rpx;
}

.cart-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #171717;
}

.quantity {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.remove-btn {
  color: #ee0000 !important;
}

.total-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-top: 1rpx solid #ebebeb;
}

.total-label {
  font-size: 28rpx;
  color: #4d4d4d;
}

.total-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #171717;
}

.order-form {
  padding: 24rpx;
}

.form-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #171717;
  margin-bottom: 16rpx;
  margin-top: 8rpx;
}

.date-scroll {
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.date-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 60rpx;
  padding: 0 24rpx;
  margin-right: 16rpx;
  border-radius: 12rpx;
  border: 1rpx solid #ebebeb;
  background: #ffffff;
  font-size: 26rpx;
  color: #4d4d4d;
}

.date-active {
  background: #171717;
  color: #ffffff;
  border-color: #171717;
}

.note-templates {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.note-chip {
  padding: 8rpx 20rpx;
  border-radius: 100rpx;
  background: #f5f5f5;
  font-size: 24rpx;
  color: #4d4d4d;
}
