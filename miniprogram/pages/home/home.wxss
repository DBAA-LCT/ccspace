.cart-btn {
  flex: 0 0 auto;
}

.product-list {
  display: grid;
  gap: 20rpx;
}

.product-card {
  overflow: hidden;
}

.product-image {
  display: block;
  width: 100%;
  height: 300rpx;
  background: #f5f5f5;
}

.product-body {
  padding: 24rpx;
}

.product-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.product-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #171717;
}

.tag {
  flex: 0 0 auto;
  border-radius: 100rpx;
  padding: 4rpx 16rpx;
  color: #4d4d4d;
  background: #fafafa;
  font-size: 22rpx;
  font-weight: 500;
}

.product-desc {
  display: block;
  margin-top: 12rpx;
  color: #888888;
  font-size: 26rpx;
  line-height: 1.5;
}

.product-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 20rpx;
}

.unit {
  color: #888888;
  font-size: 26rpx;
}

.stock {
  display: block;
  margin-top: 6rpx;
  color: #888888;
  font-size: 24rpx;
}
