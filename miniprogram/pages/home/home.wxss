.hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
  padding: 28rpx;
  background: #fffaf1;
}

.hero-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.35;
}

.hero-sub {
  display: block;
  margin-top: 10rpx;
  color: #6d675d;
  font-size: 26rpx;
  line-height: 1.45;
}

.cart-button {
  flex: 0 0 180rpx;
}

.loading,
.empty {
  padding: 48rpx 24rpx;
  color: #6d675d;
  text-align: center;
}

.product-list {
  display: grid;
  gap: 20rpx;
}

.product-card {
  overflow: hidden;
}

.product-image {
  display: block;
  width: 100%;
  height: 300rpx;
  background: #fbf1de;
}

.product-body {
  padding: 22rpx;
}

.product-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.product-name {
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.35;
}

.tag {
  flex: 0 0 auto;
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
  color: #7a5314;
  background: #fbf1de;
  font-size: 22rpx;
}

.product-desc {
  display: block;
  margin-top: 12rpx;
  color: #6d675d;
  font-size: 26rpx;
  line-height: 1.5;
}

.product-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 18rpx;
}

.stock {
  display: block;
  margin-top: 6rpx;
  color: #6d675d;
  font-size: 24rpx;
}

.add-button {
  width: 144rpx;
}

