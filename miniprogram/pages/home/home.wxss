.cart-btn {
  flex: 0 0 auto;
}

.search-bar {
  margin-bottom: 24rpx;
  padding: 18rpx;
}

.hot-searches {
  margin-bottom: 24rpx;
}

.hot-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #171717;
  margin-bottom: 16rpx;
}

.hot-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.hot-tag {
  padding: 8rpx 20rpx;
  border-radius: 100rpx;
  background: #f5f5f5;
  font-size: 24rpx;
  color: #4d4d4d;
}

.hot-section {
  margin-bottom: 24rpx;
}

.hot-scroll {
  white-space: nowrap;
}

.hot-card {
  display: inline-flex;
  flex-direction: column;
  width: 220rpx;
  margin-right: 16rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #ffffff;
  border: 1rpx solid #ebebeb;
}

.hot-img {
  width: 220rpx;
  height: 160rpx;
  background: #f5f5f5;
}

.hot-name {
  display: block;
  padding: 12rpx 12rpx 4rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #171717;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hot-card .price {
  display: block;
  padding: 0 12rpx 12rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.product-list {
  display: grid;
  gap: 20rpx;
}

.product-card {
  overflow: hidden;
}

.product-image {
  display: block;
  width: 100%;
  height: 300rpx;
  background: #f5f5f5;
}

.product-body {
  padding: 24rpx;
}

.product-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.product-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #171717;
}

.tag {
  flex: 0 0 auto;
  border-radius: 100rpx;
  padding: 4rpx 16rpx;
  color: #4d4d4d;
  background: #fafafa;
  font-size: 22rpx;
  font-weight: 500;
}

.product-desc {
  display: block;
  margin-top: 12rpx;
  color: #666666;
  font-size: 26rpx;
  line-height: 1.5;
}

.product-foot {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 20rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.original-price {
  font-size: 24rpx;
  color: #999;
  text-decoration: line-through;
}

.meta-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 6rpx;
}

.unit {
  color: #666666;
  font-size: 24rpx;
}

.rating {
  color: #f5a623;
  font-size: 22rpx;
}

.sales {
  color: #666666;
  font-size: 22rpx;
}

.stock {
  font-size: 22rpx;
}
