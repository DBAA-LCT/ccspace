<view class="page">
  <form class="panel profile-form" bindsubmit="saveProfile">
    <view class="form-title">我的信息</view>
    <t-input name="customerName" label="下单人" value="{{profile.customerName}}" placeholder="你的姓名" />
    <t-input name="customerPhone" label="手机号" value="{{profile.customerPhone}}" placeholder="用于查询订单" type="number" />
    <t-input name="receiverName" label="收货人" value="{{profile.receiverName}}" placeholder="收货人姓名" />
    <t-input name="receiverPhone" label="联系电话" value="{{profile.receiverPhone}}" placeholder="收货人电话" type="number" />
    <t-textarea name="address" label="配送地址" value="{{profile.address}}" placeholder="村名、组名、门牌或明显地标" />
    <t-textarea name="note" label="默认备注" value="{{profile.note}}" placeholder="配送偏好等" />
    <t-button theme="primary" block shape="round" form-type="submit">保存信息</t-button>
  </form>

  <view wx:if="{{monthlyStats.length > 0}}" class="panel stats-section">
    <view class="form-title">消费月报</view>
    <view class="stats-total">
      <text class="muted">累计消费</text>
      <text class="price stats-amount">￥{{totalSpent}}</text>
    </view>
    <view wx:for="{{monthlyStats}}" wx:key="month" class="stats-row">
      <text class="stats-month">{{item.month}}</text>
      <text class="stats-orders">{{item.orderCount}}单</text>
      <text class="stats-items">{{item.itemCount}}件</text>
      <text class="price stats-amount-sm">￥{{item.totalCents}}</text>
    </view>
  </view>

  <view wx:if="{{reminders.length > 0}}" class="panel reminder-section">
    <view class="form-title">定期提醒</view>
    <view wx:for="{{reminders}}" wx:key="id" class="reminder-item">
      <view class="reminder-info">
        <text class="reminder-name">{{item.productName}}</text>
        <text class="muted">每{{item.intervalDays}}天 · 下次 {{item.nextAt}}</text>
      </view>
      <t-button variant="text" size="small" data-id="{{item.id}}" bindtap="deleteReminder">取消</t-button>
    </view>
  </view>

  <view class="panel tip">
    <text class="tip-text">小程序上线前，需要把后端部署到 HTTPS 域名，并在微信公众平台配置 request 合法域名。</text>
  </view>
</view>
