.profile-form {
  padding: 24rpx;
}

.form-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #171717;
  margin-bottom: 20rpx;
}

.stats-section {
  padding: 24rpx;
}

.stats-total {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 16rpx;
  margin-bottom: 16rpx;
  border-bottom: 1rpx solid #ebebeb;
}

.stats-amount {
  font-size: 36rpx;
  font-weight: 600;
}

.stats-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.stats-row:last-child {
  border-bottom: none;
}

.stats-month {
  font-size: 26rpx;
  font-weight: 500;
  color: #171717;
  width: 140rpx;
}

.stats-orders,
.stats-items {
  font-size: 24rpx;
  color: #666666;
  width: 80rpx;
}

.stats-amount-sm {
  font-size: 26rpx;
  font-weight: 500;
  margin-left: auto;
}

.reminder-section {
  padding: 24rpx;
}

.reminder-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.reminder-item:last-child {
  border-bottom: none;
}

.reminder-info {
  flex: 1;
}

.reminder-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #171717;
  margin-bottom: 4rpx;
}

.tip {
  margin-top: 24rpx;
  padding: 24rpx;
  background: #fafafa;
  border-radius: 16rpx;
}

.tip-text {
  color: #666666;
  font-size: 24rpx;
  line-height: 1.6;
}
