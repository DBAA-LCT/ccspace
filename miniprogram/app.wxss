page {
  min-height: 100vh;
  color: #24231f;
  background: #f7f5ef;
  font-family: -apple-system, BlinkMacSystemFont, "Microsoft YaHei", sans-serif;
  letter-spacing: 0;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

.page {
  padding: 24rpx;
}

.panel {
  border: 1rpx solid #ded8cb;
  border-radius: 12rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(58, 47, 27, 0.06);
}

.muted {
  color: #6d675d;
}

.price {
  color: #a8563f;
  font-weight: 700;
}

.primary-btn {
  min-height: 76rpx;
  border-radius: 12rpx;
  color: #fff;
  background: #2f6f5e;
  font-size: 30rpx;
  line-height: 76rpx;
}

.secondary-btn {
  min-height: 64rpx;
  border: 1rpx solid #c7ded4;
  border-radius: 10rpx;
  color: #2f6f5e;
  background: #e9f3ed;
  font-size: 28rpx;
  line-height: 64rpx;
}

.danger-btn {
  color: #a8563f;
  border-color: #e4c8bd;
  background: #f7e9e3;
}

.field {
  display: block;
  margin-bottom: 20rpx;
  color: #6d675d;
  font-size: 26rpx;
}

.field input,
.field textarea {
  display: block;
  width: 100%;
  min-height: 78rpx;
  margin-top: 8rpx;
  border: 1rpx solid #ded8cb;
  border-radius: 10rpx;
  padding: 16rpx;
  color: #24231f;
  background: #fff;
  font-size: 28rpx;
}

.status {
  display: inline-flex;
  align-items: center;
  min-height: 40rpx;
  border-radius: 999rpx;
  padding: 0 16rpx;
  color: #245648;
  background: #e9f3ed;
  font-size: 24rpx;
}

.status.warn {
  color: #7a5314;
  background: #fbf1de;
}

.status.danger {
  color: #b23b3b;
  background: #fdeceb;
}

